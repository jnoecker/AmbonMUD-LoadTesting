{
  "name": "ambon-mud-load-testing",
  "version": "1.0.0",
  "description": "Load testing tool for AmbonMUD — spawns telnet/WebSocket bots with configurable behaviors",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "dashboard:dev": "cd dashboard && bun run dev",
    "dashboard:build": "cd dashboard && bun run build"
  },
  "dependencies": {
    "hono": "^4",
    "@hono/node-server": "^1",
    "js-yaml": "^4",
    "ws": "^8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^20",
    "@types/ws": "^8",
    "bun-types": "^1.3.10",
    "typescript": "^5"
  }
}
